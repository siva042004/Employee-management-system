SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host/your-db?sslmode=require
SPRING_DATASOURCE_USERNAME=your-neon-user
SPRING_DATASOURCE_PASSWORD=your-neon-password
JWT_SECRET=replace-with-a-long-random-secret-key-at-least-32-chars
AES_KEY=replace-with-exactly-32-characters!!
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
